PORT=8787
HOST=0.0.0.0
LICENSE_DB_PATH=./data/licenses.db

# Must match desktop app env LICENSE_PRODUCT_ID
LICENSE_DEFAULT_PRODUCT_ID=chordvox-pro
LICENSE_DEFAULT_OFFLINE_GRACE_HOURS=168

# Required for admin HTTP endpoints
LICENSE_SERVER_ADMIN_TOKEN=replace-with-admin-token

# Creem native license relay
CREEM_API_BASE_URL=https://api.creem.io
CREEM_API_KEY=replace-with-creem-secret-api-key

# Creem payment webhook (get from Creem dashboard → Developers → Webhook)
CREEM_WEBHOOK_SECRET=replace-with-creem-webhook-secret

# Optional: internal owner license that bypasses Creem and supports your own devices/gifts
INTERNAL_OWNER_KEY=
INTERNAL_OWNER_PLAN=owner
INTERNAL_OWNER_MAX_ACTIVATIONS=5

# Legacy AK issue/revoke tooling only (optional when fully migrated to Creem native)
LICENSE_KEY_PEPPER=replace-with-long-random-secret
